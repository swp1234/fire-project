# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.md text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.xml text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.svg binary
